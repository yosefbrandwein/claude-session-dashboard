rules_version = '2';
// Multi-tenant isolation: a signed-in user can only ever touch documents under
// their own users/{uid} subtree. This file is the ENTIRE server-side auth layer
// (no Cloud Functions — Spark free plan).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Shape-validate a NEW command: known type, pending, bounded sessionId +
    // payload text/reqId. (map.size() counts KEYS, so we guard string lengths.)
    function validCommandCreate(d) {
      return d.type in ['sendMessage','interrupt','approve','deny']
        && d.status == 'pending'
        && d.sessionId is string
        && d.sessionId.size() <= 200
        && (!('payload' in d) || !('text' in d.payload) || d.payload.text.size() <= 8000)
        && (!('payload' in d) || !('reqId' in d.payload) || d.payload.reqId.size() <= 200);
    }
    // Updates are how the agent acks/completes a command. FREEZE every
    // security-relevant field (type, sessionId, payload, createdAt) so a client
    // can't swap payload.text after review or re-arm a finished command back to
    // 'pending' (replay). Status is forward-only: never back to 'pending'.
    function validCommandUpdate(prev, next) {
      return next.type == prev.type
        && next.sessionId == prev.sessionId
        && next.get('payload', {}) == prev.get('payload', {})
        && next.get('createdAt', 0) == prev.get('createdAt', 0)
        && next.status in ['acked','done','error'];
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Devices registered by this user's agents — with a PER-DEVICE command
      // channel. Commands live here (not in a flat collection) so each agent
      // only ever sees its OWN device's commands; an agent on another device
      // can't pick up — and falsely error on — a command meant for this one.
      match /devices/{deviceId} {
        allow read, write: if isOwner(uid);
        match /commands/{cmdId} {
          allow read, delete: if isOwner(uid);
          allow create: if isOwner(uid) && validCommandCreate(request.resource.data);
          allow update: if isOwner(uid) && validCommandUpdate(resource.data, request.resource.data);
        }
      }

      // Durable session records + their sub-collections.
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
        match /messages/{messageId} {
          allow read, write: if isOwner(uid);
        }
        match /permissionRequests/{reqId} {
          allow read, write: if isOwner(uid);
        }
      }

      // Legacy flat command channel (pre per-device). Kept for back-compat with
      // any not-yet-updated agent; the current dashboard writes per-device above.
      match /commands/{cmdId} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid) && validCommandCreate(request.resource.data);
        allow update: if isOwner(uid) && validCommandUpdate(resource.data, request.resource.data);
      }
    }
  }
}
