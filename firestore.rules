rules_version = '2';
// Multi-tenant isolation: a signed-in user can only ever touch documents under
// their own users/{uid} subtree. This file is the ENTIRE server-side auth layer
// (no Cloud Functions — Spark free plan).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Devices registered by this user's agents.
      match /devices/{deviceId} {
        allow read, write: if isOwner(uid);
      }

      // Durable session records + their sub-collections.
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
        match /messages/{messageId} {
          allow read, write: if isOwner(uid);
        }
        match /permissionRequests/{reqId} {
          allow read, write: if isOwner(uid);
        }
      }

      // Dashboard -> agent control channel. Shape-validated so a compromised
      // client cannot write arbitrary command types or oversized payloads.
      match /commands/{cmdId} {
        allow read: if isOwner(uid);
        allow delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.type in ['sendMessage','interrupt','approve','deny']
          && request.resource.data.status == 'pending'
          && request.resource.data.sessionId is string
          && request.resource.data.sessionId.size() <= 200
          // Bound the injected message length. NOTE: map.size() returns the
          // number of KEYS, not bytes — so guard the text STRING's length
          // (string.size() == character count) instead.
          && (!('payload' in request.resource.data)
              || !('text' in request.resource.data.payload)
              || request.resource.data.payload.text.size() <= 8000)
          && (!('payload' in request.resource.data)
              || !('reqId' in request.resource.data.payload)
              || request.resource.data.payload.reqId.size() <= 200);
        // Updates are how the agent acks/completes a command. FREEZE every
        // security-relevant field — type, sessionId, the executable payload, and
        // createdAt — so a client (or a stolen token) cannot:
        //   • create a benign command then swap payload.text into a malicious
        //     prompt after any human/log review (payload-swap-after-review), or
        //   • re-arm a finished command back to 'pending' to make the agent's
        //     listener RE-EXECUTE it (replay / quota-amplification).
        // Status is a forward-only machine: pending → acked → done|error; an
        // update may NEVER set 'pending'.
        allow update: if isOwner(uid)
          && request.resource.data.type == resource.data.type
          && request.resource.data.sessionId == resource.data.sessionId
          && request.resource.data.get('payload', {}) == resource.data.get('payload', {})
          && request.resource.data.get('createdAt', 0) == resource.data.get('createdAt', 0)
          && request.resource.data.status in ['acked', 'done', 'error'];
      }
    }
  }
}
